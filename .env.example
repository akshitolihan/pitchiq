# Database — SQLite for local dev; swap for Postgres in production
DATABASE_URL=sqlite:///./football_analysis.db

# Tier stub — free | paid | pro   (no real auth in M1; set this to test gating)
STUB_USER_TIER=free

# Geofencing — comma-separated ISO-3166-1 alpha-2 codes to BLOCK (empty = off)
GEOFENCE_BLOCKED_COUNTRIES=

# CORS origins (comma-separated, used by FastAPI middleware)
ALLOWED_ORIGINS=http://localhost:3000

# Model fitting
TIME_DECAY_XI=0.0018

# Admin secret for triggering fit/seed jobs via HTTP
ADMIN_SECRET=change-me-before-deploy

# Live market data. Required for real football and tennis odds in the Next.js app.
ODDS_API_KEY=
# Optional: bookmaker region list for The Odds API. Common values: us, uk, eu, au.
ODDS_API_REGIONS=eu
# Optional: comma-separated The Odds API football sport keys. Leave blank for the app default list.
ODDS_API_FOOTBALL_SPORTS=

# Football live scores. Used by /live.
FOOTBALL_DATA_API_KEY=

# Supabase auth + Postgres persistence for the Next.js app.
# The app stays in local MVP mode when these are blank.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
